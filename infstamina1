local InfStamina = {}

local userInputService = game:GetService("UserInputService")
local player = game:GetService("Players").LocalPlayer

local inputStartConnection
local inputEndConnection

function InfStamina.setInfStamina(value)
    for index, v in pairs(game.Players.LocalPlayer.Character:GetChildren()) do
        if v:IsA("LocalScript") and index == 12 then
            v.Disabled = value
        end
    end

    if value then
        inputStartConnection = userInputService.InputBegan:connect(function(key)
            if key.KeyCode == Enum.KeyCode.LeftShift then
                game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 23
            end
        end)
        inputEndConnection = userInputService.InputEnded:connect(function(key) 
            if key.KeyCode == Enum.KeyCode.LeftShift then
                game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 13
            end
        end)
    else
        inputStartConnection:Disconnect()
        inputEndConnection:Disconnect()
    end
end

return InfStamina
