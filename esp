local RunService = game:GetService("RunService")
local PlayerService = game:GetService("Players")
local LocalPlayer = PlayerService.LocalPlayer

local Camera = workspace.CurrentCamera

local ESPModule = {}
ESPModule.Enabled = false
ESPModule.PlayerData = {} -- [player] = { Connection, Drawings }

local function CreateESP(player)
    if ESPModule.PlayerData[player] then return end -- already exists

    local Drawings = {
        Box = Drawing.new("Square"),
        BoxOutline = Drawing.new("Square"),
    }

    local Connection = RunService.RenderStepped:Connect(function()
        if not ESPModule.Enabled then
            Drawings.Box.Visible = false
            Drawings.BoxOutline.Visible = false
            return
        end

        local Character = player.Character
        local HumanoidRootPart = Character and Character:FindFirstChild("HumanoidRootPart")

        if HumanoidRootPart then
            local Position, OnScreen = Camera:WorldToViewportPoint(HumanoidRootPart.Position)
            if OnScreen then
                local scale = 1 / (Position.Z * math.tan(math.rad(Camera.FieldOfView * 0.5)) * 2) * 1000
                local width, height = math.floor(4.5 * scale), math.floor(6 * scale)
                local x, y = math.floor(Position.X), math.floor(Position.Y)
                local xPosition, yPosition = math.floor(x - width * 0.5), math.floor((y - height * 0.5) + (0.5 * scale))

                Drawings.BoxOutline.Size = Vector2.new(width, height)
                Drawings.BoxOutline.Position = Vector2.new(xPosition, yPosition)
                Drawings.BoxOutline.Visible = true
                Drawings.BoxOutline.Color = Color3.fromRGB(248, 185, 212)
                Drawings.BoxOutline.Thickness = 1

                Drawings.Box.Size = Vector2.new(width, height)
                Drawings.Box.Position = Vector2.new(xPosition, yPosition)
                Drawings.Box.Visible = true
                Drawings.Box.Color = Color3.fromRGB(248, 185, 212)
                Drawings.Box.Thickness = 2

                Drawings.BoxOutline.ZIndex = 1
                Drawings.Box.ZIndex = 2
            else
                Drawings.Box.Visible = false
                Drawings.BoxOutline.Visible = false
            end
        else
            Drawings.Box.Visible = false
            Drawings.BoxOutline.Visible = false
        end
    end)

    ESPModule.PlayerData[player] = { Connection = Connection, Drawings = Drawings }
end

local function RemoveESP(player)
    local data = ESPModule.PlayerData[player]
    if data then
        data.Connection:Disconnect()
        data.Drawings.Box:Remove()
        data.Drawings.BoxOutline:Remove()
        ESPModule.PlayerData[player] = nil
    end
end

function ESPModule.SetEnabled(state)
    ESPModule.Enabled = state

    if state then
        for _, v in pairs(PlayerService:GetPlayers()) do
            if v ~= LocalPlayer then
                CreateESP(v)
            end
        end
    else
        for player, _ in pairs(ESPModule.PlayerData) do
            RemoveESP(player)
        end
    end
end

PlayerService.PlayerAdded:Connect(function(v)
    task.delay(1, function()
        if ESPModule.Enabled then
            CreateESP(v)
        end
    end)
end)

PlayerService.PlayerRemoving:Connect(function(v)
    RemoveESP(v)
end)

return ESPModule
